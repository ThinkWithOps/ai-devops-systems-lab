# ── Mock mode ──────────────────────────────────────────────────────────────────
# Set to true to use mock/demo data instead of real infrastructure.
# Useful for testing the Claude Desktop integration without real K8s or AWS.
KUBE_MOCK_MODE=false

# ── AWS ────────────────────────────────────────────────────────────────────────
# Leave unset if you use aws configure / IAM instance roles instead.
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=us-east-1

# ── Kubernetes ─────────────────────────────────────────────────────────────────
# Leave unset to use the default kubeconfig (~/.kube/config).
# KUBECONFIG=/path/to/kubeconfig

# ── Docker ─────────────────────────────────────────────────────────────────────
# Leave unset to use the local Docker daemon.
# Set to remote EC2 Docker daemon after terraform apply.
# DOCKER_HOST=tcp://<EC2_IP>:2375

# ── Terraform security allowlist ───────────────────────────────────────────────
# Comma-separated absolute paths that terraform tools are allowed to operate in.
# Leave unset to allow any directory (only do this on a trusted machine).
# TERRAFORM_ALLOWED_DIRS=/home/ubuntu/terraform,/opt/infra
