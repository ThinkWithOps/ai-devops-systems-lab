# ── Groq ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── AWS ────────────────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
# Leave unset if using aws configure / IAM roles
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── S3 (set after terraform apply) ─────────────────────────────────────────────
CHROMA_S3_BUCKET=your-bucket-name-here

# ── Local ChromaDB path ────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
