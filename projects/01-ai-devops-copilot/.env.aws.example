# ─── AI DevOps Copilot — AWS Environment ─────────────────────────────────────
# Copy this to .env on your EC2 instance and fill in values.
# The setup.sh script does this automatically via Terraform user_data.

# GitHub (optional — mock data used if empty)
GITHUB_TOKEN=

# LLM — Groq (preferred on AWS, no GPU needed)
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama3-8b-8192

# Ollama (local fallback — not used on AWS with Groq)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# ChromaDB — use Docker service name on EC2
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Frontend — replace with your EC2 public IP after launch
NEXT_PUBLIC_API_URL=http://<EC2_PUBLIC_IP>:8000

# ─── AWS ──────────────────────────────────────────────────────────────────────
# On EC2 with IAM instance profile, no AWS_ACCESS_KEY_ID needed.
# Set CLOUDWATCH_ENABLED=true to read real logs from CloudWatch.
# Fallback to in-memory sample logs when false or credentials unavailable.

CLOUDWATCH_ENABLED=true
AWS_REGION=us-east-1
CLOUDWATCH_LOG_GROUP=/ai-devops-copilot/app

# Only needed if running locally without IAM role:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
