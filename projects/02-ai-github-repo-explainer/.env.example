# ============================================================
# AI GitHub Repo Explainer — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git
# ============================================================

# LLM — Groq (primary, fast, free tier available)
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# GitHub — Optional but recommended
# Without token: 60 API requests/hour (may be too low for large repos)
# With token: 5,000 API requests/hour
# Get at: GitHub Settings → Developer settings → Personal access tokens → Fine-grained
GITHUB_TOKEN=your_github_token_here

# ChromaDB — Vector database
# In Docker Compose, use the service name "chromadb"
# For local dev outside Docker, use "localhost"
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Ollama — Fallback LLM (local, free, no API key needed)
# Only used if GROQ_API_KEY is not set
# Install Ollama: https://ollama.ai/download
# Then run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
