# ── Groq (primary LLM — fast, free tier, no local install) ───────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Optional: OpenAI fallback
OPENAI_API_KEY=

# ── Local vector store fallback ───────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=infra_diagrams

# ── App ────────────────────────��───────────────────────────────��──────────────
LOG_LEVEL=info
MAX_UPLOAD_SIZE_MB=10

# ── Frontend ───────────────────────────────────────────────────────────���──────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── AWS Core (optional — required for AWS mode) ───────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AWS Bedrock — primary LLM (Claude Haiku, fast + cost-effective) ───────────
# Set to true when AWS credentials are configured and Bedrock access is enabled.
# Falls back to Ollama when false or when credentials are missing.
AWS_BEDROCK_ENABLED=false

# ── AWS S3 — primary diagram storage (persistent, presigned URLs) ─────────────
# Set to true and provide a bucket name after running terraform apply.
# Falls back to local filesystem when false.
AWS_S3_ENABLED=false
AWS_S3_BUCKET=

# ── AWS DynamoDB — primary diagram history (no container dependency) ──────────
# Set to true and provide a table name after running terraform apply.
# Falls back to ChromaDB when false.
AWS_DYNAMODB_ENABLED=false
AWS_DYNAMODB_TABLE=infra-diagram-history
